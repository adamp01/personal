---

---

<footer class="site-footer">
  <div class="site-footer-inner">
    <span class="site-footer-copy"
      >&copy; {new Date().getFullYear()} Adam Wood</span
    >
    <div class="site-footer-links">
      <a
        class="site-footer-email"
        href="mailto:adam@adampwood.com"
        aria-label="Email"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
          ></path>
        </svg>
        Email
      </a>
      <a
        class="site-footer-gh"
        href="https://github.com/adamp01/personal"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Source"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        Source
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 1.5rem;
  }

  .site-footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(255, 34, 229, 0.25);
    padding: 0.75rem 1.5rem;
  }

  .site-footer-copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.65);
    font-weight: 600;
  }

  .site-footer-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-footer-email,
  .site-footer-gh {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 80ms;
  }

  .site-footer-email:hover,
  .site-footer-gh:hover {
    color: var(--primary);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 0;
    }

    .site-footer-inner {
      padding: 0.75rem 1rem;
    }
  }
</style>
