---
import Image from "./Image.astro";

interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="hero-wrap">
  <Image
    src={src}
    alt={alt}
    width={1600}
    height={900}
    sizes="(max-width: 960px) 100vw, 1400px"
    class="hero-img"
  />
</div>
