---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  sizes?: string;
  widths?: number[];
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  quality?: number;
  fit?: "scale-down" | "contain" | "cover" | "crop" | "pad";
  format?: "auto" | "webp" | "avif" | "jpeg" | "png";
  transform?: boolean;
}

const {
  src,
  alt,
  width = 1200,
  height = 800,
  class: className = "",
  sizes,
  widths = [480, 768, 1024, 1280, 1600],
  loading = "lazy",
  decoding = "async",
  quality = 82,
  fit = "cover",
  format = "auto",
  transform,
} = Astro.props as Props;

const envTransformOverride =
  import.meta.env.PUBLIC_ENABLE_CF_IMAGE_TRANSFORMS === "true";
const shouldTransform =
  transform ?? (import.meta.env.PROD || envTransformOverride);

const toSourceImage = (url: string) => {
  if (url.startsWith("http://") || url.startsWith("https://")) return url;
  return url.replace(/^\/+/, "");
};

const buildTransformedUrl = (url: string, nextWidth: number) => {
  const sourceImage = toSourceImage(url);
  const options = [
    `fit=${fit}`,
    `width=${nextWidth}`,
    `height=${height}`,
    `quality=${quality}`,
    `format=${format}`,
  ].join(",");
  return `/cdn-cgi/image/${options}/${sourceImage}`;
};

const sortedUniqueWidths = [...new Set(widths)]
  .filter((value) => Number.isFinite(value) && value > 0)
  .sort((a, b) => a - b);

const responsiveWidths = sortedUniqueWidths.filter((value) => value <= width);
if (!responsiveWidths.includes(width)) responsiveWidths.push(width);

const srcset = responsiveWidths
  .map(
    (candidateWidth) =>
      `${shouldTransform ? buildTransformedUrl(src, candidateWidth) : src} ${candidateWidth}w`,
  )
  .join(", ");

const fallbackSrc = shouldTransform ? buildTransformedUrl(src, width) : src;
---

<img
  src={fallbackSrc}
  srcset={shouldTransform ? srcset : undefined}
  sizes={sizes}
  alt={alt}
  loading={loading}
  decoding={decoding}
  width={width}
  height={height}
  class={className}
/>
