---
import type { CollectionEntry } from "astro:content";

type TravelEntry = CollectionEntry<"travels">;

interface Props {
  entry: TravelEntry;
}

const { entry } = Astro.props;
const data = entry.data;

const durationDays =
  (new Date(data.dateEnd).getTime() - new Date(data.dateStart).getTime()) /
    (1000 * 60 * 60 * 24) +
  1;

const hasRegionMap = Boolean(data.regionSvg);
---

<aside class="trip-sidebar">
  <section class="sb-box">
    <h2>Trip overview</h2>
    <dl>
      <div>
        <dt>Dates</dt>
        <dd>{data.dateStart} &rarr; {data.dateEnd}</dd>
      </div>
      <div>
        <dt>Duration</dt>
        <dd>{durationDays} days</dd>
      </div>
      <div>
        <dt>Countries</dt>
        <dd>{data.countries.join(", ")}</dd>
      </div>
      {
        data.rating && (
          <div>
            <dt>Rating</dt>
            <dd>{data.rating} &#9733;</dd>
          </div>
        )
      }
      {
        data.categories.length > 0 && (
          <div>
            <dt>Categories</dt>
            <dd>{data.categories.join(", ")}</dd>
          </div>
        )
      }
    </dl>
  </section>

  {
    hasRegionMap && (
      <section class="sb-box">
        <h2>Route</h2>
        <div class="region-map-wrap">
          <svg viewBox="0 0 100 100" class="region-map">
            <defs>
              <marker
                id="arrowhead"
                markerWidth="6"
                markerHeight="6"
                refX="5"
                refY="3"
                orient="auto"
              >
                <path d="M0,0 L0,6 L6,3 z" fill="#ff22e5" />
              </marker>
            </defs>

            <image href={data.regionSvg} x="0" y="0" width="100" height="100" />

            {data.regionRoutes.map((r) => {
              const from = data.regionPoints[r.from];
              const to = data.regionPoints[r.to];
              if (!from || !to) return null;
              return (
                <line
                  x1={from.x}
                  y1={from.y}
                  x2={to.x}
                  y2={to.y}
                  class="route-line"
                  marker-end="url(#arrowhead)"
                />
              );
            })}

            {data.regionPoints.map((p) => (
              <g>
                <circle cx={p.x} cy={p.y} r="2" class="poi-circle" />
                <text x={p.x + 3.5} y={p.y + 1} class="poi-label">
                  {p.name}
                </text>
              </g>
            ))}
          </svg>
        </div>
      </section>
    )
  }

  {
    data.cities.length > 0 && (
      <section class="sb-box">
        <h2>Places visited</h2>
        <ul>
          {data.cities.map((c) => (
            <li>{c.name}</li>
          ))}
        </ul>
      </section>
    )
  }
</aside>

<style>
  .trip-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 1.5rem;
  }

  .sb-box {
    border: 2px solid var(--primary);
    box-shadow: 3px 3px 0 var(--accent);
    padding: 1rem 1rem 1.1rem;
    background: rgba(255, 34, 229, 0.06);
  }

  .sb-box h2 {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 0.6rem;
  }

  dl {
    margin: 0;
  }

  dl > div {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.85rem;
    padding-block: 0.2rem;
    border-bottom: 1px solid rgba(255, 34, 229, 0.2);
  }

  dl > div:last-child {
    border-bottom: none;
  }

  dt {
    color: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
  }

  dd {
    margin: 0;
    font-weight: 700;
    text-align: right;
    color: var(--text);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }

  ul li {
    padding: 0.2rem 0;
    border-bottom: 1px solid rgba(255, 34, 229, 0.2);
  }

  ul li:last-child {
    border-bottom: none;
  }

  .region-map-wrap {
    margin-top: 0.5rem;
  }

  .region-map {
    width: 100%;
    height: auto;
    display: block;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 34, 229, 0.3);
  }

  .route-line {
    stroke: #ff22e5;
    stroke-width: 0.8;
    stroke-linecap: round;
  }

  .poi-circle {
    fill: var(--accent);
    stroke: var(--bg);
    stroke-width: 0.5;
  }

  .poi-label {
    font-size: 4.5px;
    fill: var(--accent);
    font-family: sans-serif;
    font-weight: bold;
    stroke: var(--bg);
    stroke-width: 0.3;
  }

  @media (max-width: 900px) {
    .trip-sidebar {
      position: static;
    }
  }
</style>
