---
interface Props {
  label?: string;
}

const { label = "Note" } = Astro.props;
---

<aside class="note">
  <span class="note-label">{label}</span>
  <div class="note-body">
    <slot />
  </div>
</aside>

<style>
  .note {
    border: var(--border);
    box-shadow: var(--shadow-sm);
    padding: 1rem 1.25rem;
    margin: 2rem 0;
    position: relative;
    background: color-mix(in srgb, var(--primary) 6%, var(--bg));
  }

  .note-label {
    position: absolute;
    top: -0.6rem;
    left: 0.75rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--primary);
    background: var(--bg);
    padding: 0 0.4rem;
  }

  .note-body {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text);
  }

  .note-body :global(p) {
    margin-bottom: 0;
  }

  .note-body :global(p + p) {
    margin-top: 0.75rem;
  }
</style>
