---
interface Props {
  slug: string;
  title: string;
  date: string;
  excerpt: string;
  categories: string[];
}

const { slug, title, date, excerpt, categories } = Astro.props;

const formatted = new Date(date).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<article class="thought-card">
  <a href={`/thoughts/${slug}`}>
    <div class="thought-card-body">
      <div class="thought-main">
        <h2>{title}</h2>
        <p class="thought-excerpt">{excerpt}</p>
      </div>
      <div class="thought-meta">
        <p class="thought-date">{formatted}</p>
        {
          categories.length > 0 && (
            <ul class="thought-categories">
              {categories.map((cat) => (
                <li>{cat}</li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </a>
</article>

<style>
  .thought-card {
    border: var(--border);
    box-shadow: var(--shadow);
    background: var(--bg);
    min-width: 0;
    overflow: hidden;
    transition:
      box-shadow 80ms,
      transform 80ms;
  }

  .thought-card:hover {
    box-shadow: 6px 6px 0 var(--primary);
    transform: translate(-1px, -1px);
  }

  .thought-card a {
    color: inherit;
    text-decoration: none;
    display: block;
    min-width: 0;
  }

  .thought-card-body {
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .thought-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .thought-main h2 {
    font-size: 1.05rem;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .thought-excerpt {
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .thought-meta {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    min-width: 9rem;
  }

  .thought-date {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
    white-space: nowrap;
  }

  .thought-categories {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .thought-categories li {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--primary);
    color: var(--primary);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .thought-card-body {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
      padding: 0.9rem 1.25rem;
    }

    .thought-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .thought-main h2,
    .thought-excerpt {
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
    }
  }
</style>
