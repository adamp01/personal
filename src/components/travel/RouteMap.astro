---
import type { CollectionEntry } from "astro:content";
import SidebarBox from "./SidebarBox.astro";

type TravelData = CollectionEntry<"travels">["data"];

interface Props {
  regionSvg: TravelData["regionSvg"];
  regionRoutes: TravelData["regionRoutes"];
  regionPoints: TravelData["regionPoints"];
}

const { regionSvg, regionRoutes, regionPoints } = Astro.props;

const placeNames = regionPoints.map((p) => p.name).join(", ");
const mapTitle = placeNames ? `Route map showing: ${placeNames}` : "Route map";
const svgTitleId = `route-map-title-${Math.random().toString(36).slice(2, 8)}`;
---

<SidebarBox title="Route">
  <div class="region-map-wrap">
    <svg
      viewBox="0 0 100 100"
      class="region-map"
      role="img"
      aria-labelledby={svgTitleId}
    >
      <title id={svgTitleId}>{mapTitle}</title>
      <defs>
        <marker
          id="arrowhead"
          markerWidth="6"
          markerHeight="6"
          refX="5"
          refY="3"
          orient="auto"
        >
          <path d="M0,0 L0,6 L6,3 z" fill="#ff22e5"></path>
        </marker>
      </defs>

      <image href={regionSvg} x="0" y="0" width="100" height="100" />

      {
        regionRoutes.map((r) => {
          const from = regionPoints[r.from];
          const to = regionPoints[r.to];
          if (!from || !to) return null;
          return (
            <line
              x1={from.x}
              y1={from.y}
              x2={to.x}
              y2={to.y}
              class="route-line"
              marker-end="url(#arrowhead)"
            />
          );
        })
      }

      {
        regionPoints.map((p) => (
          <g>
            <circle cx={p.x} cy={p.y} r="2" class="poi-circle" />
            <text x={p.x + 3.5} y={p.y + 1} class="poi-label">
              {p.name}
            </text>
          </g>
        ))
      }
    </svg>
  </div>
</SidebarBox>

<style>
  .region-map-wrap {
    margin-top: 0.5rem;
  }

  .region-map {
    width: 100%;
    height: auto;
    display: block;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 34, 229, 0.3);
  }

  .route-line {
    stroke: #ff22e5;
    stroke-width: 0.8;
    stroke-linecap: round;
  }

  .poi-circle {
    fill: var(--accent);
    stroke: var(--bg);
    stroke-width: 0.5;
  }

  .poi-label {
    font-size: 4.5px;
    fill: var(--accent);
    font-family: sans-serif;
    font-weight: bold;
    stroke: var(--bg);
    stroke-width: 0.3;
  }
</style>
