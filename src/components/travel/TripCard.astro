---
import ImageBase from "~/components/image/ImageBase.astro";
import { getMonthLabel } from "~/utils/date";

interface Props {
  slug: string;
  title: string;
  countries: string[];
  year: number;
  months: string[];
  days: number;
  rating?: number;
  coverImage?: string;
}

const { slug, title, countries, year, months, days, rating, coverImage } =
  Astro.props;

const monthLabel = getMonthLabel(months, year, true);
---

<article class="trip-card">
  <a href={`/travels/${slug}`}>
    {
      coverImage && (
        <ImageBase src={coverImage} alt={title} width={800} height={500} />
      )
    }
    <div class="trip-card-body">
      <h2>{title}</h2>
      <p class="trip-meta">
        {countries.join(", ")} &middot; {monthLabel} &middot; {days} days
        {rating && <span> &middot; {rating} &#9733;</span>}
      </p>
    </div>
  </a>
</article>

<style>
  .trip-card {
    border: var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
    background: var(--bg);
    transition:
      box-shadow 80ms,
      transform 80ms;
  }

  .trip-card:hover {
    box-shadow: 6px 6px 0 var(--primary);
    transform: translate(-1px, -1px);
  }

  .trip-card a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .trip-card :global(img) {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-bottom: var(--border);
  }

  .trip-card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .trip-card-body h2 {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .trip-meta {
    font-size: 0.825rem;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
</style>
