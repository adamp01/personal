---
import type { CollectionEntry } from "astro:content";
import TripOverview from "./TripOverview.astro";
import RouteMap from "./RouteMap.astro";
import PlacesVisited from "./PlacesVisited.astro";

type TravelEntry = CollectionEntry<"travels">;

interface Props {
  entry: TravelEntry;
}

const { entry } = Astro.props;
const data = entry.data;
---

<aside class="trip-sidebar">
  <TripOverview data={data} />

  {
    data.regionSvg && (
      <RouteMap
        regionSvg={data.regionSvg}
        regionRoutes={data.regionRoutes}
        regionPoints={data.regionPoints}
      />
    )
  }

  {data.cities.length > 0 && <PlacesVisited cities={data.cities} />}
</aside>

<style>
  .trip-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 1.5rem;
  }

  @media (max-width: 900px) {
    .trip-sidebar {
      position: static;
    }
  }
</style>
