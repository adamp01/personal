---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
}

const { title = "Adam Wood" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Navbar />

    <div class="page-content">
      <slot />
    </div>

    <Footer />
  </body>
</html>

<style is:global>
  /* ── Design tokens ─────────────────────────────────────────── */
  :root {
    --text: #ffffff;
    --bg: #080b36;
    --primary: #ff22e5;
    --secondary: #ffffff;
    --accent: #32c411;

    --border: 2px solid var(--primary);
    --shadow: 5px 5px 0 var(--accent);
    --shadow-sm: 3px 3px 0 var(--accent);

    --nav-h: 56px;

    --font-sans: "Inter", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", monospace;
  }

  /* ── Reset / base ──────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    scroll-padding-top: calc(var(--nav-h) + 1rem);
  }

  body {
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-content {
    flex: 1;
  }

  /* ── Typography ────────────────────────────────────────────── */
  h1,
  h2,
  h3,
  h4 {
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
  }
  h2 {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  h3 {
    font-size: 1.1rem;
  }

  p {
    line-height: 1.7;
  }

  /* ── Links ─────────────────────────────────────────────────── */
  a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Layout containers ─────────────────────────────────────── */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.5rem 1.5rem 5rem;
  }

  /* ── Section label ─────────────────────────────────────────── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  /* ── Page header ───────────────────────────────────────────── */
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: var(--border);
  }

  .page-header h1 {
    margin-top: 0.3rem;
  }

  /* ── Article prose ─────────────────────────────────────────── */
  .prose h2,
  .prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    border-left: 4px solid var(--primary);
    padding-left: 0.75rem;
  }

  .prose p {
    margin-bottom: 1.75rem;
  }

  .prose img {
    display: block;
    width: 100%;
    height: auto;
  }

  .prose figcaption {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.4rem;
    text-align: center;
    font-style: italic;
  }

  /* ── Hero image ────────────────────────────────────────────── */
  .hero-wrap {
    margin: 0 0 2rem;
    border: var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-wrap img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* ── Scrollbar ─────────────────────────────────────────────── */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--primary);
  }
</style>
