---
import { ClientRouter } from "astro:transitions";
import Navbar from "~/components/Navbar.astro";
import Footer from "~/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Adam Wood",
  description = "Personal site of Adam Wood — developer, traveller, builder.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Navbar />

    <main id="main-content" class="page-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  /* ── Design tokens ─────────────────────────────────────────── */
  :root {
    --text: #e8e8e8;
    --bg: #080b36;
    --primary: #ff22e5;
    --secondary: #e8e8e8;
    --accent: #54e134;

    --border: 2px solid var(--primary);
    --shadow: 5px 5px 0 var(--accent);
    --shadow-sm: 3px 3px 0 var(--accent);

    --nav-h: 56px;
    --content-width: 70ch;

    --font-sans: "Inter", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", monospace;

    --selection-bg: rgba(255, 34, 229, 0.612);
    --selection-color: var(--bg);
  }

  ::selection {
    background: var(--selection-bg);
    color: var(--selection-color);
  }

  ::-moz-selection {
    background: var(--selection-bg);
    color: var(--selection-color);
  }

  /* ── Skip link ─────────────────────────────────────────────── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: var(--primary);
    color: var(--bg);
    font-weight: 800;
    font-size: 0.875rem;
    text-decoration: none;
    transition: top 0ms;
  }

  .skip-link:focus {
    top: 1rem;
  }

  /* ── Reset / base ──────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: var(--font-sans);
    font-size: 17px;
    background: var(--bg);
    color: var(--text);
    scroll-padding-top: calc(var(--nav-h) + 1rem);
  }

  body {
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-content {
    flex: 1;
  }

  /* ── Typography ────────────────────────────────────────────── */
  h1,
  h2,
  h3,
  h4 {
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
  }
  h2 {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  h3 {
    font-size: 1.1rem;
  }

  p {
    line-height: 1.7;
  }

  /* ── Links ─────────────────────────────────────────────────── */
  a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  a:focus-visible,
  button:focus-visible,
  [tabindex]:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ── Layout containers ─────────────────────────────────────── */
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0.5rem 1.5rem 5rem;
  }

  /* ── Section label ─────────────────────────────────────────── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  /* ── Page header ───────────────────────────────────────────── */
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: var(--border);
  }

  .page-header h1 {
    margin-top: 0.3rem;
  }

  /* ── Inline code ───────────────────────────────────────────── */
  :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: #ff88f4;
    background: rgba(255, 34, 229, 0.12);
    border-radius: 0;
    padding: 0.15em 0.4em;
  }

  /* ── Code blocks ────────────────────────────────────────────── */
  pre.astro-code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    padding: 1rem 1.25rem;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    overflow-x: auto;
    margin: 1.5rem 0;
    border-radius: 0;
  }

  pre.astro-code code {
    font-family: inherit;
    font-size: inherit;
    background: none;
    padding: 0;
    color: inherit;
  }

  /* ── Article prose ─────────────────────────────────────────── */
  .prose {
    max-width: var(--content-width);
    font-size: 1.0588rem; /* ~18px at 17px base */
    line-height: 1.8;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    border-left: 4px solid var(--primary);
    padding-left: 0.75rem;
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose p:has(+ figure) {
    margin-bottom: 0.5rem;
  }

  .prose p + ul,
  .prose p + ol {
    margin-top: -1rem;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.25rem;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .prose li {
    margin-bottom: 0.35rem;
    line-height: 1.8;
  }

  .prose li:last-child {
    margin-bottom: 0;
  }

  .prose img {
    display: block;
    width: 100%;
    height: auto;
  }

  .prose figcaption {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.4rem;
    text-align: center;
    font-style: italic;
  }

  /* ── Hero image ────────────────────────────────────────────── */
  .hero-wrap {
    margin: 0 0 2rem;
    border: var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-wrap img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* ── Scrollbar ─────────────────────────────────────────────── */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--primary);
  }
</style>
