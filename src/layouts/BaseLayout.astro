---
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
}

const { title = "Adam Wood" } = Astro.props;
const path = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <header class="topnav" id="topnav">
      <div class="topnav-inner">
        <a href="/" class="topnav-logo">
          <img
            src="/favicon.svg"
            alt="Adam's personal website"
            width="42"
            height="42"
            transition:persist
          />
        </a>

        <nav
          class="topnav-links"
          id="topnav-links"
          aria-label="Main navigation"
        >
          <a href="/" class:list={["topnav-link", { active: path === "/" }]}
            >About</a
          >
          <a
            href="/travels"
            class:list={[
              "topnav-link",
              { active: path.startsWith("/travels") },
            ]}>Travels</a
          >
        </nav>

        <button
          class="topnav-burger"
          id="topnav-burger"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="topnav-links"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <slot />

    <script>
      function initBurger() {
        const burger = document.getElementById("topnav-burger")!;
        const links = document.getElementById("topnav-links")!;

        burger.addEventListener("click", () => {
          const open = links.classList.toggle("is-open");
          burger.setAttribute("aria-expanded", String(open));
          burger.classList.toggle("is-open", open);
        });

        // Close menu when a link is tapped on mobile
        links.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", () => {
            links.classList.remove("is-open");
            burger.classList.remove("is-open");
            burger.setAttribute("aria-expanded", "false");
          });
        });
      }

      // Re-run after every client-side navigation (Astro View Transitions)
      document.addEventListener("astro:page-load", initBurger);
    </script>
  </body>
</html>

<style is:global>
  /* ── Design tokens ─────────────────────────────────────────── */
  :root {
    --text: #ffffff;
    --bg: #080b36;
    --primary: #ff22e5;
    --secondary: #ffffff;
    --accent: #32c411;

    --border: 2px solid var(--primary);
    --shadow: 5px 5px 0 var(--accent);
    --shadow-sm: 3px 3px 0 var(--accent);

    --nav-h: 56px;

    --font-sans: "Inter", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", monospace;
  }

  /* ── Reset / base ──────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    scroll-padding-top: calc(var(--nav-h) + 1rem);
  }

  body {
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── Top nav ───────────────────────────────────────────────── */
  .topnav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-h);
    background: var(--bg);
    /* border-bottom: var(--border); */
  }

  .topnav-inner {
    max-width: 960px;
    margin: 0 auto;
    height: 100%;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .topnav-logo {
    display: flex;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    margin-right: auto;
  }

  .topnav-logo:hover {
    color: var(--primary);
    text-decoration: none;
  }

  .topnav-links {
    display: flex;
    gap: 0.5rem;
  }

  .topnav-link {
    display: inline-block;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
    border: 2px solid var(--primary);
    text-decoration: none;
    transition:
      background 80ms,
      color 80ms,
      border-color 80ms;
  }

  .topnav-link:hover {
    background: var(--secondary);
    color: var(--bg);
    border-color: var(--secondary);
    text-decoration: none;
  }

  .topnav-link.active {
    background: var(--primary);
    color: var(--bg);
    border-color: var(--primary);
    text-decoration: none;
  }

  /* ── Hamburger ─────────────────────────────────────────────── */
  .topnav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: transparent;
    border: 2px solid var(--primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  .topnav-burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--primary);
    transition:
      transform 200ms,
      opacity 200ms;
    transform-origin: center;
  }

  /* Animate to X when open */
  .topnav-burger.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .topnav-burger.is-open span:nth-child(2) {
    opacity: 0;
  }
  .topnav-burger.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 640px) {
    .topnav-burger {
      display: flex;
    }

    .topnav-links {
      display: none;
      position: absolute;
      top: var(--nav-h);
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--bg);
      border-bottom: var(--border);
      z-index: 99;
    }

    .topnav-links.is-open {
      display: flex;
    }

    .topnav-link {
      padding: 1rem 1.5rem;
      border: none;
      border-bottom: 1px solid rgba(255, 34, 229, 0.25);
      font-size: 1rem;
    }

    .topnav-link:last-child {
      border-bottom: none;
    }
  }

  /* ── Typography ────────────────────────────────────────────── */
  h1,
  h2,
  h3,
  h4 {
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
  }
  h2 {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  h3 {
    font-size: 1.1rem;
  }

  p {
    line-height: 1.7;
  }

  /* ── Links ─────────────────────────────────────────────────── */
  a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Layout containers ─────────────────────────────────────── */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.5rem 1.5rem 5rem;
  }

  /* ── Section label ─────────────────────────────────────────── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  /* ── Page header rule ──────────────────────────────────────── */
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: var(--border);
  }

  .page-header h1 {
    margin-top: 0.3rem;
  }

  /* ── Trip card ─────────────────────────────────────────────── */
  .trip-card {
    border: var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
    background: var(--bg);
    transition:
      box-shadow 80ms,
      transform 80ms;
  }

  .trip-card:hover {
    box-shadow: 6px 6px 0 var(--primary);
    transform: translate(-1px, -1px);
  }

  .trip-card a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .trip-card img {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-bottom: var(--border);
  }

  .trip-card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .trip-card-body h2 {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .trip-meta {
    font-size: 0.825rem;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  /* ── Trip grid ─────────────────────────────────────────────── */
  .trip-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  /* ── Article prose ─────────────────────────────────────────── */
  .prose h2,
  .prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    border-left: 4px solid var(--primary);
    padding-left: 0.75rem;
  }

  .prose p {
    margin-bottom: 1.75rem;
  }

  .prose img {
    display: block;
    width: 100%;
    height: auto;
  }

  .prose figcaption {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.4rem;
    text-align: center;
    font-style: italic;
  }

  /* ── Hero image ────────────────────────────────────────────── */
  .hero-wrap {
    margin: 0 0 2rem;
    border: var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-wrap img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* ── Scrollbar ─────────────────────────────────────────────── */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--primary);
  }
</style>
