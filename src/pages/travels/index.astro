---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImageBase from "../../components/post/ImageBase.astro";

const travels = await getCollection("travels");
travels.sort((a, b) => (a.data.dateStart < b.data.dateStart ? 1 : -1));
---

<BaseLayout title="Travels – My Travel Journal">
  <div class="container">
    <header class="page-header">
      <p class="section-label">All trips</p>
      <h1>Travels</h1>
    </header>

    <div class="trip-grid">
      {
        travels.map((entry) => {
          const d = entry.data;
          const duration =
            (new Date(d.dateEnd).getTime() - new Date(d.dateStart).getTime()) /
              (1000 * 60 * 60 * 24) +
            1;

          return (
            <article class="trip-card">
              <a href={`/travels/${entry.slug}`}>
                {d.coverImage && (
                  <ImageBase
                    src={d.coverImage}
                    alt={d.title}
                    width={800}
                    height={500}
                  />
                )}
                <div class="trip-card-body">
                  <h2>{d.title}</h2>
                  <p class="trip-meta">
                    {d.countries.join(", ")} &middot; {duration} days
                    {d.rating && <span> &middot; {d.rating} &#9733;</span>}
                  </p>
                </div>
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
