---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import TripCard from "~/components/TripCard.astro";

const travels = await getCollection("travels");
travels.sort((a, b) => (a.data.dateStart < b.data.dateStart ? 1 : -1));
---

<BaseLayout title="Travels – Adam Wood">
  <div class="container">
    <header class="page-header">
      <p class="section-label">All travels</p>
      <h1>Travels</h1>
    </header>

    <div class="trip-grid">
      {
        travels.map((entry) => (
          <TripCard
            slug={entry.slug}
            title={entry.data.title}
            countries={entry.data.countries}
            dateStart={entry.data.dateStart}
            dateEnd={entry.data.dateEnd}
            rating={entry.data.rating}
            coverImage={entry.data.coverImage}
          />
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .trip-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
